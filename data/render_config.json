{
  "version": "v2-cinematic-1",
  "_comment": "V2 cinematic-gold render style — the architectural-masterplan look (sun + soft VSM shadows + PMREM IBL + metal material + patina), ported from sandbox/cinematic_gold_sandbox.html per sandbox/CINEMATIC_GOLD_MIGRATION.md. Authoritative values = sandbox/cinematic_gold_state.json (the agreed checkpoint). COLOR is still DATA: classes/_defaults/layers drive per-building + per-room color; global.cinematic holds only material PHYSICS + lighting + tone (constant across layers). See architecture/rendering.md 'Cinematic render style'. Fog near/far are WORLD-SCALE — tune in the browser smoke-test.",
  "global": {
    "background": "#0a0a0c",
    "fog": { "enabled": true, "color": "#0a0a0c", "near": 3000, "far": 16000 },
    "bloom": { "enabled": true, "strength": 0.07, "radius": 0.5, "threshold": 0.85 },
    "cinematic": {
      "exposure": 1.48,
      "environment": "studio",
      "sun": { "azimuth": 171, "elevation": 28, "intensity": 2.55, "color": "#fff1da" },
      "shadow": { "enabled": true, "softness": 4.5, "mapSize": 2048, "bias": -0.0006, "normalBias": 1.5 },
      "ambient": 0.48,
      "ao": { "enabled": false, "radius": 0.75, "scale": 3 },
      "material": {
        "metalness": 0.25,
        "roughness": 0.51,
        "envMapIntensity": 1.55,
        "patina": 0.21,
        "contextPatina": 0.37,
        "envelopeOpacity": 0.56,
        "roomOpacity": 0.2
      },
      "edges": {
        "envelope": { "on": true, "color": "#ffffff", "thickness": 0.2, "opacity": 0.46, "worldScale": 1.5 },
        "room": { "on": true, "color": "#ffffff", "thickness": 0, "opacity": 0.5, "worldScale": 1.5 }
      }
    },
    "classes": {
      "building": { "fill": { "color": "#888888", "opacity": 0.56 }, "edge": { "thickness": 0.2, "brightness": 0.85 } },
