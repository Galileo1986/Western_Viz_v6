      "floor": { "fill": { "color": "#5c5c5c", "opacity": 0.0 }, "edge": { "thickness": 0.8, "brightness": 0.22 } },
      "context": { "fill": { "color": "#222225", "opacity": 1.0 }, "edge": { "thickness": 0.8, "brightness": 0.2 } }
    },
    "selection": { "color": "#c8f24a", "opacity": 1.0 },
    "missingData": { "color": "#4a4e52", "opacity": 0.55 },
    "byScope": {
      "campus": {
        "classes": {
          "room": { "fill": { "opacity": 0.2 } },
          "context": { "fill": { "opacity": 1.0 } }
        }
      },
      "building": {
        "classes": {
          "room": { "fill": { "opacity": 0.9 } },
          "context": { "fill": { "opacity": 0.0 } }
